.product-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.product-card:active {
  background: #f9f9f9;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 36rpx;
}

.product-code {
  font-size: 22rpx;
  color: #999999;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 60%;
}

.product-location {
  font-size: 22rpx;
  color: #999999;
  flex-shrink: 0;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  overflow: hidden;
}

.product-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.product-quantity {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
  flex-shrink: 0;
}
