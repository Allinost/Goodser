.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  gap: 16rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  height: 72rpx;
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.search-clear {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-btn {
  padding: 0 24rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1890ff;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}
