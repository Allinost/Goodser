/* Goodser 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #ffffff;
}

/* 搜索栏容器 */
.search-wrapper {
  padding: 16rpx 24rpx;
  background: #ffffff;
}

/* 按钮基础 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: #1890ff;
  color: #ffffff;
}

.btn-danger {
  background: #ff4d4f;
  color: #ffffff;
}

.btn-ghost {
  background: transparent;
  color: #1890ff;
  border: 2rpx solid #1890ff;
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-blue {
  background: #e6f7ff;
  color: #1890ff;
}

.tag-orange {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-green {
  background: #f6ffed;
  color: #52c41a;
}

.tag-red {
  background: #fff2f0;
  color: #ff4d4f;
}

.tag-gray {
  background: #f5f5f5;
  color: #999999;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-container .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-container .empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 底部固定操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-bar .btn {
  flex: 1;
  margin: 0 8rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row .label {
  color: #999999;
  font-size: 26rpx;
}

.info-row .value {
  color: #333333;
  font-size: 26rpx;
  font-weight: 500;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-bottom: 2rpx solid #f5f5f5;
}

.list-item:active {
  background: #f9f9f9;
}
