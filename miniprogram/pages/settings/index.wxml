<view class="page-settings">
  <!-- 用户信息 -->
  <view class="user-card card">
    <image class="user-avatar" src="https://picsum.photos/100/100?random=101" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">管理员</text>
      <text class="user-role">admin</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-group">
    <view class="settings-item" bindtap="onWhitelist">
      <view class="settings-left">
        <text class="settings-icon">👥</text>
        <text class="settings-label">访问白名单</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{whitelistCount}} 人</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" bindtap="onStatusCodes">
      <view class="settings-left">
        <text class="settings-icon">📋</text>
        <text class="settings-label">状态编码管理</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{statusCodeCount}} 个</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" bindtap="onTags">
      <view class="settings-left">
        <text class="settings-icon">🏷️</text>
        <text class="settings-label">标签管理</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{tagCount}} 个</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" bindtap="onNasConfig">
      <view class="settings-left">
        <text class="settings-icon">💾</text>
        <text class="settings-label">NAS 存储配置</text>
      </view>
      <view class="settings-right">
        <text class="settings-value {{nasConnected ? 'connected' : 'disconnected'}}">{{nasConnected ? '已连接' : '未连接'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 数据存储 -->
  <view class="section-title">数据存储</view>
  <view class="settings-group">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">☁️</text>
        <view class="settings-label-group">
          <text class="settings-label">云数据库</text>
          <text class="settings-hint">启用后数据将存储至微信云开发。免费额度：数据库读 5 万次/月、写 3 万次/月、云函数 100 万次/月。</text>
        </view>
      </view>
      <view class="settings-right">
        <switch checked="{{cloudDbEnabled}}" bindchange="onCloudDbToggle" color="#1890ff" />
      </view>
    </view>
  </view>

  <!-- 云数据库状态 -->
  <view class="settings-group" wx:if="{{cloudDbEnabled}}">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📡</text>
        <text class="settings-label">连接状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value {{cloudDbStatus === '已连接' ? 'connected' : 'disconnected'}}">{{cloudDbStatus}}</text>
      </view>
    </view>
  </view>

  <!-- 数据同步 -->
  <view class="section-title">数据同步</view>
  <view class="settings-group">
    <!-- 同步所有数据 -->
    <view class="settings-item sync-all-item" bindtap="onSyncAllData">
      <view class="settings-left">
        <text class="settings-icon">🔄</text>
        <view class="settings-label-group">
          <text class="settings-label">同步所有数据</text>
          <text class="settings-hint">从后端（云开发 / NAS 私有云）重新拉取全部数据：目录、商品、出库单、入库日志、标签、状态编码、白名单</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- 同步状态 -->
    <view class="settings-item cache-stats" wx:if="{{syncing}}">
      <view class="settings-left">
        <text class="settings-icon loading-icon">⏳</text>
        <text class="settings-label sync-progress">{{syncProgress}}</text>
      </view>
    </view>

    <!-- 上次同步时间 -->
    <view class="settings-item cache-stats" wx:if="{{lastSyncTime}}">
      <view class="settings-left">
        <text class="settings-icon">🕐</text>
        <view class="settings-label-group">
          <text class="settings-label">上次全量同步</text>
          <text class="settings-hint">{{lastSyncTime}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 缓存管理 -->
  <view class="section-title">缓存管理</view>
  <view class="settings-group">
    <!-- 分级 TTL 开关 -->
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">⏱️</text>
        <view class="settings-label-group">
          <text class="settings-label">分级 TTL 缓存</text>
          <text class="settings-hint">按数据类型自动设置缓存过期时间（默认关闭，缓存永不过期）</text>
        </view>
      </view>
      <view class="settings-right">
        <switch checked="{{gradedTTL}}" bindchange="onGradedTTLToggle" color="#faad14" />
      </view>
    </view>

    <!-- 缓存统计 -->
    <view class="settings-item cache-stats">
      <view class="settings-left">
        <text class="settings-icon">📊</text>
        <text class="settings-label">缓存状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">L1: {{cacheL1Count}}项 | L2: {{cacheStorageCount}}项 / {{cacheStorageKB}}KB</text>
      </view>
    </view>

    <!-- 强制刷新缓存 -->
    <view class="settings-item" bindtap="onForceRefresh">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <view class="settings-label-group">
          <text class="settings-label">强制刷新缓存</text>
          <text class="settings-hint">清除本地缓存标记，下次访问页面时重新从后端拉取</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- 清理操作 -->
    <view class="settings-item" bindtap="onClearAllCache">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <view class="settings-label-group">
          <text class="settings-label">清理所有缓存</text>
          <text class="settings-hint">清除 L1 内存 + L2 Storage + 差量标记，下次重新全量拉取</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <view class="settings-item" bindtap="onClearStaleCache">
      <view class="settings-left">
        <text class="settings-icon">🧹</text>
        <view class="settings-label-group">
          <text class="settings-label">清理过期缓存</text>
          <text class="settings-hint">仅删除已过期的缓存，保留有效数据</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 差量同步信息 -->
  <view class="settings-group" wx:if="{{cloudDbEnabled && syncInfo.length > 0}}">
    <view class="section-inner-title">差量同步追踪</view>
    <view class="settings-item" wx:for="{{syncInfo}}" wx:key="inventoryId">
      <view class="settings-left">
        <text class="settings-icon">📦</text>
        <view class="settings-label-group">
          <text class="settings-label">仓库 {{item.inventoryId}}</text>
          <text class="settings-hint">版本 {{item.version}} · 上次同步 {{item.lastSyncTime}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 图片缓存 -->
  <view class="section-title">图片缓存</view>
  <view class="settings-group">
    <view class="settings-item cache-stats">
      <view class="settings-left">
        <text class="settings-icon">🖼️</text>
        <text class="settings-label">图片缓存状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{imageCacheCount}} 张 / {{imageCacheKB}}KB</text>
      </view>
    </view>

    <view class="settings-item" bindtap="onClearImageCache">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <view class="settings-label-group">
          <text class="settings-label">清理全部图片缓存</text>
          <text class="settings-hint">删除所有本地缓存的商品图片</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <view class="settings-item" bindtap="onClearUnusedImages">
      <view class="settings-left">
        <text class="settings-icon">🧹</text>
        <view class="settings-label-group">
          <text class="settings-label">清理未使用图片</text>
          <text class="settings-hint">删除未被任何商品引用的冗余图片</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section-title">关于</view>
  <view class="settings-group">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">ℹ️</text>
        <text class="settings-label">关于 Goodser</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">v1.0.0</text>
      </view>
    </view>
  </view>
</view>
