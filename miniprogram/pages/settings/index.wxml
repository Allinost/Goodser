<view class="page-settings">
  <!-- 用户信息 -->
  <view class="user-card card">
    <!-- <image class="user-avatar" src="https://picsum.photos/100/100?random=101" mode="aspectFill" /> -->
    <image class="user-avatar" src="https://avatars.githubusercontent.com/u/214270487?s=200&v=4" mode="aspectFill" />
    <view class="user-info">
      <text class="user-name">管理员</text>
      <text class="user-role">admin</text>
    </view>
  </view>

  <!-- 基本设置 -->
  <view wx:if="{{showWhitelist || showStatusCodes || showTags || showSelfBuiltConfig || showNasConfig}}">
  <view class="settings-group">
    <view class="settings-item" wx:if="{{showWhitelist}}" bindtap="onWhitelist">
      <view class="settings-left">
        <text class="settings-icon">👥</text>
        <text class="settings-label">访问白名单</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{whitelistCount}} 人</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" wx:if="{{showStatusCodes}}" bindtap="onStatusCodes">
      <view class="settings-left">
        <text class="settings-icon">📋</text>
        <text class="settings-label">状态编码管理</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{statusCodeCount}} 个</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" wx:if="{{showTags}}" bindtap="onTags">
      <view class="settings-left">
        <text class="settings-icon">🏷️</text>
        <text class="settings-label">标签管理</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{tagCount}} 个</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" wx:if="{{showSelfBuiltConfig}}" bindtap="onSelfBuiltConfig">
      <view class="settings-left">
        <text class="settings-icon">🖥️</text>
        <view class="settings-label-group">
          <text class="settings-label">自建后端配置</text>
          <text class="settings-hint">Rust API 后端（test.hailong.site / et.hailong.site）</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-value {{selfBuiltStatus === '已连接' ? 'connected' : 'disconnected'}}">{{selfBuiltStatus === '已连接' ? '已连接' : selfBuiltEnabled ? selfBuiltStatus : '未配置'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item" wx:if="{{showNasConfig}}" bindtap="onNasConfig">
      <view class="settings-left">
        <text class="settings-icon">💾</text>
        <text class="settings-label">NAS 存储配置</text>
      </view>
      <view class="settings-right">
        <text class="settings-value {{nasConnected ? 'connected' : 'disconnected'}}">{{nasConnected ? '已连接' : '未连接'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>
  </view>

  <!-- 数据存储 -->
  <view wx:if="{{showCloudDb || showCloudDbStatus || showSelfBuilt || showSelfBuiltStatus}}">
  <view class="section-title" wx:if="{{showCloudDb || showCloudDbStatus || showSelfBuilt || showSelfBuiltStatus}}">数据存储</view>
  <view class="settings-group" wx:if="{{showCloudDb}}">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">☁️</text>
        <view class="settings-label-group">
          <text class="settings-label">云数据库</text>
          <text class="settings-hint">启用后数据将存储至微信云开发。免费额度：数据库读 5 万次/月、写 3 万次/月、云函数 100 万次/月。</text>
        </view>
      </view>
      <view class="settings-right">
        <switch checked="{{cloudDbEnabled}}" bindchange="onCloudDbToggle" color="#1890ff" />
      </view>
    </view>
  </view>

  <!-- 云数据库状态 -->
  <view class="settings-group" wx:if="{{showCloudDbStatus && cloudDbEnabled}}">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📡</text>
        <text class="settings-label">连接状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value {{cloudDbStatus === '已连接' ? 'connected' : 'disconnected'}}">{{cloudDbStatus}}</text>
      </view>
    </view>
  </view>

  <!-- 自建后端开关 -->
  <view class="settings-group" wx:if="{{showSelfBuilt}}">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🖥️</text>
        <view class="settings-label-group">
          <text class="settings-label">自建后端</text>
          <text class="settings-hint">启用后连接自建 Rust 后端 API（test.hailong.site），数据存储在 MySQL</text>
        </view>
      </view>
      <view class="settings-right">
        <switch checked="{{selfBuiltEnabled}}" bindchange="onSelfBuiltToggle" color="#52c41a" />
      </view>
    </view>
  </view>

  <!-- 自建后端状态 -->
  <view class="settings-group" wx:if="{{showSelfBuiltStatus && selfBuiltEnabled}}">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📡</text>
        <text class="settings-label">连接状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value {{selfBuiltStatus === '已连接' ? 'connected' : 'disconnected'}}">{{selfBuiltStatus}}</text>
      </view>
    </view>
  </view>
  </view>

  <!-- 数据同步 -->
  <view wx:if="{{showSyncAll || showSyncProgress || showLastSync}}">
  <view class="section-title" wx:if="{{showSyncAll || showSyncProgress || showLastSync}}">数据同步</view>
  <view class="settings-group">
    <!-- 同步所有数据 -->
    <view class="settings-item sync-all-item" wx:if="{{showSyncAll}}" bindtap="onSyncAllData">
      <view class="settings-left">
        <text class="settings-icon">🔄</text>
        <view class="settings-label-group">
          <text class="settings-label">同步所有数据</text>
          <text class="settings-hint">从后端（云开发 / NAS 私有云）重新拉取全部数据：目录、商品、出库单、入库日志、标签、状态编码、白名单</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- 同步状态 -->
    <view class="settings-item cache-stats" wx:if="{{showSyncProgress && syncing}}">
      <view class="settings-left">
        <text class="settings-icon loading-icon">⏳</text>
        <text class="settings-label sync-progress">{{syncProgress}}</text>
      </view>
    </view>

    <!-- 上次同步时间 -->
    <view class="settings-item sync-detail-item" wx:if="{{showLastSync && lastSyncTime}}" bindtap="onViewLastSyncDetail">
      <view class="settings-left">
        <text class="settings-icon">🕐</text>
        <view class="settings-label-group">
          <text class="settings-label">上次全量同步</text>
          <text class="settings-hint">{{lastSyncTime}}</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>
  </view>

  <!-- 缓存管理 -->
  <view wx:if="{{showGradedTTL || showCacheStatus || showForceRefresh || showClearAllCache || showClearStaleCache || showDiffSync}}">
  <view class="section-title" wx:if="{{showGradedTTL || showCacheStatus || showForceRefresh || showClearAllCache || showClearStaleCache || showDiffSync}}">缓存管理</view>
  <view class="settings-group">
    <!-- 分级 TTL 开关 -->
    <view class="settings-item" wx:if="{{showGradedTTL}}">
      <view class="settings-left">
        <text class="settings-icon">⏱️</text>
        <view class="settings-label-group">
          <text class="settings-label">分级 TTL 缓存</text>
          <text class="settings-hint">按数据类型自动设置缓存过期时间（默认关闭，缓存永不过期）</text>
        </view>
      </view>
      <view class="settings-right">
        <switch checked="{{gradedTTL}}" bindchange="onGradedTTLToggle" color="#faad14" />
      </view>
    </view>

    <!-- 缓存统计 -->
    <view class="settings-item cache-stats" wx:if="{{showCacheStatus}}">
      <view class="settings-left">
        <text class="settings-icon">📊</text>
        <text class="settings-label">缓存状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">L1: {{cacheL1Count}}项 | L2: {{cacheStorageCount}}项 / {{cacheStorageKB}}KB</text>
      </view>
    </view>

    <!-- 强制刷新缓存 -->
    <view class="settings-item" wx:if="{{showForceRefresh}}" bindtap="onForceRefresh">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <view class="settings-label-group">
          <text class="settings-label">强制刷新缓存</text>
          <text class="settings-hint">清除本地缓存标记，下次访问页面时重新从后端拉取</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- 清理操作 -->
    <view class="settings-item" wx:if="{{showClearAllCache}}" bindtap="onClearAllCache">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <view class="settings-label-group">
          <text class="settings-label">清理所有缓存</text>
          <text class="settings-hint">清除 L1 内存 + L2 Storage + 差量标记，下次重新全量拉取</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <view class="settings-item" wx:if="{{showClearStaleCache}}" bindtap="onClearStaleCache">
      <view class="settings-left">
        <text class="settings-icon">🧹</text>
        <view class="settings-label-group">
          <text class="settings-label">清理过期缓存</text>
          <text class="settings-hint">仅删除已过期的缓存，保留有效数据</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 差量同步信息 -->
  <view class="settings-group" wx:if="{{showDiffSync && cloudDbEnabled && syncInfo.length > 0}}">
    <view class="section-inner-title">差量同步追踪</view>
    <view class="settings-item" wx:for="{{syncInfo}}" wx:key="inventoryId">
      <view class="settings-left">
        <text class="settings-icon">📦</text>
        <view class="settings-label-group">
          <text class="settings-label">仓库 {{item.inventoryId}}</text>
          <text class="settings-hint">版本 {{item.version}} · 上次同步 {{item.lastSyncTime}}</text>
        </view>
      </view>
    </view>
  </view>
  </view>

  <!-- 图片缓存 -->
  <view wx:if="{{showImageCacheStatus || showClearImageCache || showClearUnusedImages}}">
  <view class="section-title" wx:if="{{showImageCacheStatus || showClearImageCache || showClearUnusedImages}}">图片缓存</view>
  <view class="settings-group">
    <view class="settings-item cache-stats" wx:if="{{showImageCacheStatus}}">
      <view class="settings-left">
        <text class="settings-icon">🖼️</text>
        <text class="settings-label">图片缓存状态</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">{{imageCacheCount}} 张 / {{imageCacheKB}}KB</text>
      </view>
    </view>

    <view class="settings-item" wx:if="{{showClearImageCache}}" bindtap="onClearImageCache">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <view class="settings-label-group">
          <text class="settings-label">清理全部图片缓存</text>
          <text class="settings-hint">删除所有本地缓存的商品图片</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <view class="settings-item" wx:if="{{showClearUnusedImages}}" bindtap="onClearUnusedImages">
      <view class="settings-left">
        <text class="settings-icon">🧹</text>
        <view class="settings-label-group">
          <text class="settings-label">清理未使用图片</text>
          <text class="settings-hint">删除未被任何商品引用的冗余图片</text>
        </view>
      </view>
      <view class="settings-right">
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>
  </view>

  <!-- 关于 -->
  <view wx:if="{{showAboutSection}}">
  <view class="section-title" wx:if="{{showAboutSection}}">关于</view>
  <view class="settings-group">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">ℹ️</text>
        <text class="settings-label">关于 Goodser</text>
      </view>
      <view class="settings-right">
        <text class="settings-value">v1.0.0</text>
      </view>
    </view>
  </view>
  </view>

  <!-- 设置项显示控制 -->
  <view class="settings-group toggle-display-group">
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">👥</text>
        <text class="settings-label">访问白名单</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showWhitelist}}" bindchange="onToggleSetting" data-key="showWhitelist" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📋</text>
        <text class="settings-label">状态编码管理</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showStatusCodes}}" bindchange="onToggleSetting" data-key="showStatusCodes" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🏷️</text>
        <text class="settings-label">标签管理</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showTags}}" bindchange="onToggleSetting" data-key="showTags" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🖥️</text>
        <text class="settings-label">自建后端配置</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showSelfBuiltConfig}}" bindchange="onToggleSetting" data-key="showSelfBuiltConfig" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">💾</text>
        <text class="settings-label">NAS 存储配置</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showNasConfig}}" bindchange="onToggleSetting" data-key="showNasConfig" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">☁️</text>
        <text class="settings-label">云数据库</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showCloudDb}}" bindchange="onToggleSetting" data-key="showCloudDb" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📡</text>
        <text class="settings-label">云数据库状态</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showCloudDbStatus}}" bindchange="onToggleSetting" data-key="showCloudDbStatus" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🖥️</text>
        <text class="settings-label">自建后端</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showSelfBuilt}}" bindchange="onToggleSetting" data-key="showSelfBuilt" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📡</text>
        <text class="settings-label">自建后端状态</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showSelfBuiltStatus}}" bindchange="onToggleSetting" data-key="showSelfBuiltStatus" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🔄</text>
        <text class="settings-label">同步所有数据</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showSyncAll}}" bindchange="onToggleSetting" data-key="showSyncAll" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">⏳</text>
        <text class="settings-label">同步进度</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showSyncProgress}}" bindchange="onToggleSetting" data-key="showSyncProgress" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🕐</text>
        <text class="settings-label">上次全量同步</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showLastSync}}" bindchange="onToggleSetting" data-key="showLastSync" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">⏱️</text>
        <text class="settings-label">分级 TTL 缓存</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showGradedTTL}}" bindchange="onToggleSetting" data-key="showGradedTTL" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📊</text>
        <text class="settings-label">缓存状态</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showCacheStatus}}" bindchange="onToggleSetting" data-key="showCacheStatus" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <text class="settings-label">强制刷新缓存</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showForceRefresh}}" bindchange="onToggleSetting" data-key="showForceRefresh" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <text class="settings-label">清理所有缓存</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showClearAllCache}}" bindchange="onToggleSetting" data-key="showClearAllCache" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🧹</text>
        <text class="settings-label">清理过期缓存</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showClearStaleCache}}" bindchange="onToggleSetting" data-key="showClearStaleCache" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">📦</text>
        <text class="settings-label">差量同步追踪</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showDiffSync}}" bindchange="onToggleSetting" data-key="showDiffSync" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🖼️</text>
        <text class="settings-label">图片缓存状态</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showImageCacheStatus}}" bindchange="onToggleSetting" data-key="showImageCacheStatus" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🗑️</text>
        <text class="settings-label">清理全部图片缓存</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showClearImageCache}}" bindchange="onToggleSetting" data-key="showClearImageCache" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">🧹</text>
        <text class="settings-label">清理未使用图片</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showClearUnusedImages}}" bindchange="onToggleSetting" data-key="showClearUnusedImages" color="#1890ff" />
      </view>
    </view>
    <view class="settings-item">
      <view class="settings-left">
        <text class="settings-icon">ℹ️</text>
        <text class="settings-label">关于 Goodser</text>
      </view>
      <view class="settings-right">
        <switch checked="{{showAboutSection}}" bindchange="onToggleSetting" data-key="showAboutSection" color="#1890ff" />
      </view>
    </view>
  </view>

  <!-- 全量同步详情弹窗 -->
  <view class="sync-detail-mask" wx:if="{{showSyncDetail}}" bindtap="onSyncDetailMaskTap">
    <view class="sync-detail-dialog" catchtap="">
      <view class="sync-detail-header">
        <text class="sync-detail-title">全量同步详情</text>
        <text class="sync-detail-close" bindtap="hideSyncDetail">✕</text>
      </view>
      <view class="sync-detail-body">
        <view class="sync-detail-row">
          <text class="sdr-label">同步时间</text>
          <text class="sdr-value">{{syncDetailForShow.syncTime}}</text>
        </view>
        <view class="sync-detail-divider"></view>
        <view class="sync-detail-section-title">汇总统计</view>
        <view class="sync-detail-grid">
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.totalInventories}}</text>
            <text class="sdg-label">库存目录</text>
          </view>
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.totalProducts}}</text>
            <text class="sdg-label">商品总数</text>
          </view>
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.totalOrders}}</text>
            <text class="sdg-label">出库单</text>
          </view>
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.totalLogs}}</text>
            <text class="sdg-label">入库日志</text>
          </view>
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.tagCount}}</text>
            <text class="sdg-label">标签</text>
          </view>
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.statusCodeCount}}</text>
            <text class="sdg-label">状态编码</text>
          </view>
          <view class="sdg-item">
            <text class="sdg-value">{{syncDetailForShow.whitelistCount}}</text>
            <text class="sdg-label">白名单人数</text>
          </view>
        </view>
        <view class="sync-detail-divider" wx:if="{{syncDetailForShow.invDetails.length > 0}}"></view>
        <view class="sync-detail-section-title" wx:if="{{syncDetailForShow.invDetails.length > 0}}">各仓库明细</view>
        <view class="sync-detail-inv-list" wx:if="{{syncDetailForShow.invDetails.length > 0}}">
          <view class="sdi-item" wx:for="{{syncDetailForShow.invDetails}}" wx:key="name">
            <view class="sdi-header">
              <text class="sdi-name">📦 {{item.name}}</text>
            </view>
            <view class="sdi-stats">
              <text class="sdi-stat">商品: {{item.productCount}} 个</text>
              <text class="sdi-stat">出库单: {{item.orderCount}} 个</text>
              <text class="sdi-stat">入库日志: {{item.logCount}} 条</text>
            </view>
          </view>
        </view>
      </view>
      <view class="sync-detail-footer">
        <view class="btn btn-primary sync-detail-btn" bindtap="hideSyncDetail">关闭</view>
      </view>
    </view>
  </view>
</view>
