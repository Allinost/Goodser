.page-tags {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.tag-list {
  background: #ffffff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tag-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.tag-item:last-child {
  border-bottom: none;
}

.tag-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-color-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.tag-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.tag-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tag-count {
  font-size: 24rpx;
  color: #999999;
}

.tag-edit {
  font-size: 26rpx;
  color: #1890ff;
}

.tag-delete {
  font-size: 26rpx;
  color: #ff4d4f;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.add-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.color-option {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
}

.color-option-active {
  border-color: #333333;
  transform: scale(1.1);
}

.color-check {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.3);
}

/* 弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333333;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.dialog-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-actions .btn {
  flex: 1;
  text-align: center;
}
