.page-settings {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 32rpx 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #f0f0f0;
}

.user-info {
  margin-left: 20rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 24rpx;
  color: #999999;
}

/* 分组标题 */
.section-title {
  margin: 32rpx 24rpx 12rpx;
  font-size: 24rpx;
  color: #999999;
  letter-spacing: 2rpx;
}

/* 分组内嵌标题（差量同步） */
.section-inner-title {
  padding: 16rpx 24rpx 8rpx;
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 设置列表 */
.settings-group {
  margin: 0 24rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background: #f9f9f9;
}

.settings-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.settings-label {
  font-size: 30rpx;
  color: #333333;
}

.settings-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.settings-value {
  font-size: 26rpx;
  color: #999999;
  margin-right: 8rpx;
}

.connected {
  color: #52c41a;
}

.disconnected {
  color: #ff4d4f;
}

.settings-label-group {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.settings-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
  line-height: 1.4;
}

.settings-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 缓存统计项（非可点击） */
.cache-stats:active {
  background: transparent;
}
