.page-settings {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 32rpx 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #f0f0f0;
}

.user-info {
  margin-left: 20rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 24rpx;
  color: #999999;
}

/* 分组标题 */
.section-title {
  margin: 32rpx 24rpx 12rpx;
  font-size: 24rpx;
  color: #999999;
  letter-spacing: 2rpx;
}

/* 分组内嵌标题（差量同步） */
.section-inner-title {
  padding: 16rpx 24rpx 8rpx;
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 设置列表 */
.settings-group {
  margin: 0 24rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background: #f9f9f9;
}

.settings-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.settings-label {
  font-size: 30rpx;
  color: #333333;
}

.settings-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.settings-value {
  font-size: 26rpx;
  color: #999999;
  margin-right: 8rpx;
}

.connected {
  color: #52c41a;
}

.disconnected {
  color: #ff4d4f;
}

.settings-label-group {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.settings-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
  line-height: 1.4;
}

.settings-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 缓存统计项（非可点击） */
.cache-stats:active {
  background: transparent;
}

/* 全量同步按钮 */
.sync-all-item {
  border-left: 6rpx solid #52c41a;
}

.sync-all-item .settings-label {
  color: #52c41a;
  font-weight: 600;
}

/* 加载动画 */
.loading-icon {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.sync-progress {
  font-size: 26rpx;
  color: #1890ff;
}

/* 同步详情入口（可点击） */
.sync-detail-item:active {
  background: #f0f7ff;
}

/* 同步详情弹窗 */
.sync-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sync-detail-dialog {
  width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sync-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
}

.sync-detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
}

.sync-detail-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.sync-detail-body {
  padding: 0 32rpx 24rpx;
  overflow-y: auto;
  flex: 1;
}

.sync-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.sdr-label {
  font-size: 28rpx;
  color: #666666;
}

.sdr-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.sync-detail-divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}

.sync-detail-section-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.sync-detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sdg-item {
  flex: 0 0 calc(33.33% - 12rpx);
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sdg-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1890ff;
  line-height: 1.2;
}

.sdg-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.sync-detail-inv-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sdi-item {
  background: #f9f9f9;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
}

.sdi-header {
  margin-bottom: 8rpx;
}

.sdi-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.sdi-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sdi-stat {
  font-size: 24rpx;
  color: #666666;
}

.sync-detail-footer {
  padding: 20rpx 32rpx 32rpx;
  border-top: 2rpx solid #f5f5f5;
}

.sync-detail-btn {
  width: 100%;
  text-align: center;
}

/* 设置项显示控制 */
.toggle-display-group {
  margin-top: 32rpx;
}
