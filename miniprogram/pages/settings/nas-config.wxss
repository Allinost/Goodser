.page-nas-config {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 状态卡片 */
.status-card {
  margin: 20rpx 24rpx;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
}

.status-connected {
  background: #52c41a;
  box-shadow: 0 0 12rpx rgba(82, 196, 26, 0.4);
}

.status-disconnected {
  background: #ff4d4f;
  box-shadow: 0 0 12rpx rgba(255, 77, 79, 0.4);
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.status-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 表单 */
.card {
  margin: 20rpx 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

/* 开关设置 */
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-left {
  flex: 1;
  margin-right: 20rpx;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-bar .btn {
  flex: 1;
  text-align: center;
}
