<view class="page-nas-config">
  <!-- 连接状态 -->
  <view class="status-card card">
    <view class="status-indicator">
      <view class="status-dot {{connected ? 'status-connected' : 'status-disconnected'}}"></view>
      <text class="status-text">{{connected ? '后端已连接' : '后端未连接'}}</text>
    </view>
    <text class="status-desc" wx:if="{{!connected}}">请配置自建后端连接信息以使用 Rust API</text>
    <text class="status-desc" wx:else>后端地址: {{configBaseUrl}}</text>
  </view>

  <!-- 快速选择 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">快速选择</text>
      <view class="preset-list">
        <view class="preset-item {{preset === 'public' ? 'preset-active' : ''}}" data-preset="public" bindtap="onSelectPreset">
          <text class="preset-name">公网访问</text>
          <text class="preset-url">bak.hailong.site:8080</text>
        </view>
        <view class="preset-item {{preset === 'easytier' ? 'preset-active' : ''}}" data-preset="easytier" bindtap="onSelectPreset">
          <text class="preset-name">EasyTier 组网</text>
          <text class="preset-url">10.144.144.14:8080</text>
        </view>
        <view class="preset-item {{preset === 'custom' ? 'preset-active' : ''}}" data-preset="custom" bindtap="onSelectPreset">
          <text class="preset-name">自定义</text>
          <text class="preset-url">手动输入地址</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 连接配置 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">后端地址</text>
      <input class="form-input" placeholder="如: bak.hailong.site:8080" value="{{backendAddress}}" bindinput="onAddressInput" />
    </view>
    <view class="form-group">
      <text class="form-label">API 密钥</text>
      <input class="form-input" placeholder="API Key（可选）" password="{{true}}" value="{{apiKey}}" bindinput="onApiKeyInput" />
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="btn btn-ghost" bindtap="onTestConnection">测试连接</view>
    <view class="btn btn-primary" bindtap="onSave">保存配置</view>
  </view>
</view>
