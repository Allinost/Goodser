<view class="page-tags">
  <!-- 标签列表 -->
  <view class="tag-list">
    <view class="tag-item" wx:for="{{tags}}" wx:key="_id">
      <view class="tag-left">
        <view class="tag-color-dot" style="background: {{item.color}}"></view>
        <text class="tag-name">{{item.name}}</text>
      </view>
      <view class="tag-right">
        <text class="tag-count">{{item.productCount || 0}} 件商品</text>
        <text class="tag-edit" bindtap="onEditTag" data-id="{{item._id}}">编辑</text>
        <text class="tag-delete" bindtap="onDeleteTag" data-id="{{item._id}}">删除</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-hint" wx:if="{{tags.length === 0}}">
    <text>暂无标签，点击下方添加</text>
  </view>

  <!-- 添加标签按钮 -->
  <view class="add-bar">
    <view class="btn btn-primary" bindtap="onAddTag">+ 添加标签</view>
  </view>

  <!-- 添加/编辑标签弹窗 -->
  <view class="picker-mask" wx:if="{{showDialog}}" bindtap="hideDialog">
    <view class="dialog" catchtap="">
      <view class="dialog-title">{{editingTagId ? '编辑标签' : '添加标签'}}</view>
      <view class="form-group">
        <text class="form-label">标签名称</text>
        <input class="dialog-input" placeholder="如: 热销、新品" value="{{tagName}}" bindinput="onNameInput" />
      </view>
      <view class="form-group">
        <text class="form-label">标签颜色</text>
        <view class="color-picker">
          <view
            class="color-option {{selectedColor === item ? 'color-option-active' : ''}}"
            wx:for="{{colorOptions}}"
            wx:key="*this"
            style="background: {{item}}"
            bindtap="onSelectColor"
            data-color="{{item}}"
          >
            <text class="color-check" wx:if="{{selectedColor === item}}">✓</text>
          </view>
        </view>
      </view>
      <view class="dialog-actions">
        <view class="btn btn-ghost" bindtap="hideDialog">取消</view>
        <view class="btn btn-primary" bindtap="onConfirmSave">确认</view>
      </view>
    </view>
  </view>
</view>
