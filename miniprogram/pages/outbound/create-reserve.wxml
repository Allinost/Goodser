<view class="page-create-outbound">
  <!-- 选择库存目录 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">预留目录 <text class="required">*</text></text>
      <picker range="{{inventoryNames}}" value="{{inventoryIndex}}" bindchange="onInventoryChange">
        <view class="form-picker">
          <text>{{inventoryNames[inventoryIndex] || '请选择'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 预留信息 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">预留信息</text>
      <input class="form-input" placeholder="请输入预留信息" value="{{orderInfo}}" bindinput="onOrderInfoInput" />
    </view>
    <view class="form-group">
      <text class="form-label">预留备注</text>
      <textarea class="form-textarea" placeholder="请输入备注" value="{{orderRemark}}" bindinput="onRemarkInput" maxlength="200" />
    </view>
  </view>

  <!-- 搜索添加商品 -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">预留商品</text>
    </view>
    <search-bar
      placeholder="搜索商品名称..."
      bind:search="onProductSearch"
      bind:clear="onClearProductSearch"
    />

    <!-- 搜索结果 -->
    <view class="search-results" wx:if="{{searchResults.length > 0 && showSearchResults}}">
      <view class="multi-select-bar">
        <text class="multi-select-toggle" bindtap="onToggleMultiSelect">
          {{multiSelectMode ? '取消多选' : '多选'}}
        </text>
        <view class="multi-select-confirm-btn" wx:if="{{multiSelectMode && checkedProductIds.length > 0}}" bindtap="onConfirmMultiSelect" style="background: #fa8c16;">
          确认添加 ({{checkedProductIds.length}})
        </view>
      </view>
      <view class="search-result-item {{multiSelectMode && checkedProductIds.indexOf(item._id) > -1 ? 'search-result-item-checked' : ''}}" wx:for="{{searchResults}}" wx:key="_id" bindtap="onAddProduct" data-product="{{item}}">
        <view class="multi-checkbox" wx:if="{{multiSelectMode}}">
          <view class="checkbox-inner {{checkedProductIds.indexOf(item._id) > -1 ? 'checkbox-checked' : ''}}"></view>
        </view>
        <image class="result-image" src="{{item.image_url || '/images/placeholder.png'}}" mode="aspectFill" />
        <view class="result-info">
          <text class="result-name">{{item.name}}</text>
          <text class="result-code">{{item.code}}</text>
          <text class="result-stock">库存: {{item.quantity}}{{item.reserved_quantity > 0 ? ' + ' + item.reserved_quantity : ''}}</text>
        </view>
        <text class="result-add" wx:if="{{!multiSelectMode}}">+ 添加</text>
      </view>
    </view>

    <!-- 已选商品列表 -->
    <view class="selected-list" wx:if="{{selectedItems.length > 0}}">
      <view class="divider"></view>
      <view class="selected-item" wx:for="{{selectedItems}}" wx:key="product_id">
        <image class="selected-image" src="{{item.image_url || '/images/placeholder.png'}}" mode="aspectFill" />
        <view class="selected-info">
          <text class="selected-name">{{item.product_name}}</text>
          <text class="selected-stock">库存: {{item.stock}}</text>
        </view>
        <view class="qty-control">
          <text class="qty-btn" bindtap="onDecreaseQty" data-index="{{index}}">-</text>
          <text class="qty-value">{{item.quantity}}</text>
          <text class="qty-btn" bindtap="onIncreaseQty" data-index="{{index}}">+</text>
        </view>
        <text class="remove-btn" bindtap="onRemoveItem" data-index="{{index}}">✕</text>
      </view>
    </view>
  </view>

  <!-- 提示 -->
  <view class="reserve-tip card" wx:if="{{selectedItems.length > 0}}">
    <text class="tip-icon">ℹ️</text>
    <text class="tip-text">预留后库存数量将锁定，取消预留后恢复</text>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="btn btn-primary btn-block {{submitting ? 'btn-disabled' : ''}}" style="background: #fa8c16;" bindtap="{{submitting ? '' : 'onSubmit'}}">{{submitting ? '创建中...' : '确认新建预留单'}}</view>
  </view>
</view>
