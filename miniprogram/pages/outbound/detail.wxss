.page-outbound-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.order-header-card {
  margin: 20rpx 24rpx;
}

.order-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
}

.order-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.order-type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.order-type-tag-blue {
  background: #e6f7ff;
  color: #1890ff;
}

.order-type-tag-orange {
  background: #fff7e6;
  color: #fa8c16;
}

.meta-item {
  font-size: 24rpx;
  color: #999999;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.outbound-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.outbound-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 16rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.item-code {
  font-size: 22rpx;
  color: #999999;
  font-family: 'Courier New', monospace;
}

.item-qty {
  font-size: 30rpx;
  font-weight: 600;
  color: #1890ff;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.order-summary {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  padding: 8rpx 0;
}

.bottom-bar .btn-ghost {
  border: 2rpx solid #ff4d4f;
  color: #ff4d4f;
  background: #ffffff;
}
