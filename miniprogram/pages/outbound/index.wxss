.page-outbound {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #ffffff;
}

.inventory-picker {
  flex-shrink: 0;
}

.inventory-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.selector-arrow {
  font-size: 20rpx;
  color: #999999;
}

.top-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn-sm {
  padding: 14rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.action-btn-primary {
  background: #1890ff;
}

.action-btn-orange {
  background: #fa8c16;
}

/* 旧版大按钮样式保留兼容 */
.top-actions-bar {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #ffffff;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.action-icon {
  font-size: 32rpx;
}

/* Tab */
.tab-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-left {
  display: flex;
  flex: 1;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-active {
  font-weight: 600;
}

.tab-active-blue {
  color: #1890ff;
}

.tab-active-blue::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #1890ff;
  border-radius: 3rpx;
}

.tab-active-orange {
  color: #fa8c16;
}

.tab-active-orange::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #fa8c16;
  border-radius: 3rpx;
}

.filter-btn {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
  margin-right: 24rpx;
}

/* 统计 */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.stats-text {
  font-size: 24rpx;
  color: #999999;
}

.order-list {
  padding: 16rpx 24rpx;
}

/* 分页 */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-top: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.page-btn {
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
}

.page-btn:active {
  background: #e6f7ff;
}

.page-btn-disabled {
  color: #cccccc;
  pointer-events: none;
}

.page-info {
  font-size: 26rpx;
  color: #666666;
}

/* 弹窗遮罩 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.picker-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  overflow-y: auto;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.picker-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

/* 筛选面板 */
.filter-content {
  padding: 24rpx;
}

.filter-group {
  margin-bottom: 32rpx;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
}

.filter-tag-active {
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 500;
}

.filter-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f0f0f0;
}

.filter-footer .btn {
  flex: 1;
  text-align: center;
}
