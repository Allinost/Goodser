<view class="page-outbound">
  <!-- 库存目录选择 + 操作按钮 -->
  <view class="top-bar">
    <picker class="inventory-picker" range="{{inventoryNames}}" value="{{inventoryIndex}}" bindchange="onInventoryChange">
      <view class="inventory-selector">
        <text>{{inventoryNames[inventoryIndex]}}</text>
        <text class="selector-arrow">▼</text>
      </view>
    </picker>
    <view class="top-actions">
      <view class="action-btn-sm action-btn-primary" bindtap="onCreateOutbound">
        <text>📤 出库</text>
      </view>
      <view class="action-btn-sm action-btn-orange" bindtap="onCreateReserve">
        <text>📋 预留</text>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <search-bar
    placeholder="搜索单号、商品名称..."
    value="{{searchKeyword}}"
    bind:search="onSearch"
    bind:clear="onClearSearch"
  />

  <!-- Tab 切换 + 筛选 -->
  <view class="tab-bar">
    <view class="tab-left">
      <view
        class="tab-item {{activeTab === 'all' ? 'tab-active tab-active-blue' : ''}}"
        bindtap="onTabChange"
        data-tab="all"
      >全部</view>
      <view
        class="tab-item {{activeTab === 'outbound' ? 'tab-active tab-active-blue' : ''}}"
        bindtap="onTabChange"
        data-tab="outbound"
      >出库单</view>
      <view
        class="tab-item {{activeTab === 'reserve' ? 'tab-active tab-active-orange' : ''}}"
        bindtap="onTabChange"
        data-tab="reserve"
      >预留单</view>
    </view>
    <view class="filter-btn" bindtap="onFilter">
      <text>筛选</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-bar" wx:if="{{totalCount > 0}}">
    <text class="stats-text">共 {{totalCount}} 条记录</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{pagedOrders.length > 0}}">
    <order-card
      wx:for="{{pagedOrders}}"
      wx:key="_id"
      order="{{item}}"
      bind:tap="onOrderTap"
    />
    <!-- 分页 -->
    <view class="pagination" wx:if="{{totalPages > 1}}">
      <view class="page-btn {{currentPage <= 1 ? 'page-btn-disabled' : ''}}" bindtap="onPrevPage">上一页</view>
      <text class="page-info">{{currentPage}} / {{totalPages}}</text>
      <view class="page-btn {{currentPage >= totalPages ? 'page-btn-disabled' : ''}}" bindtap="onNextPage">下一页</view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:else
    icon="📤"
    title="暂无出库记录"
    description="点击上方按钮创建出库单或预留单"
  />

  <!-- 筛选弹窗 -->
  <view class="picker-mask" wx:if="{{showFilter}}" bindtap="hideFilter">
    <view class="picker-panel" catchtap="">
      <view class="picker-header">
        <text class="picker-title">筛选条件</text>
        <text class="picker-close" bindtap="hideFilter">✕</text>
      </view>
      <view class="filter-content">
        <view class="filter-group">
          <text class="filter-label">订单状态</text>
          <view class="filter-tags">
            <view
              class="filter-tag {{filterStatus === item.key ? 'filter-tag-active' : ''}}"
              wx:for="{{statusOptions}}"
              wx:key="key"
              bindtap="onFilterStatus"
              data-val="{{item.key}}"
            >{{item.label}}</view>
          </view>
        </view>
      </view>
      <view class="filter-footer">
        <view class="btn btn-ghost" bindtap="onResetFilter">重置</view>
        <view class="btn btn-primary" bindtap="onApplyFilter">确认筛选</view>
      </view>
    </view>
  </view>
</view>
