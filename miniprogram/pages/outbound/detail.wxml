<view class="page-outbound-detail">
  <!-- 订单头部 -->
  <view class="card order-header-card">
    <view class="order-header-row">
      <text class="order-no">{{order.order_no}}</text>
      <text class="tag {{statusTagClass}}">{{statusLabel}}</text>
    </view>
    <view class="order-meta">
      <text class="order-type-tag {{order.type === 'reserve' ? 'order-type-tag-orange' : 'order-type-tag-blue'}}">{{order.type === 'outbound' ? '出库单' : '预留单'}}</text>
      <text class="meta-item">{{order._createdAt}}</text>
    </view>
    <view class="info-row" wx:if="{{order.order_info}}">
      <text class="label">订单信息</text>
      <text class="value">{{order.order_info}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="label">备注</text>
      <text class="value">{{order.remark}}</text>
    </view>
    <view class="info-row" wx:if="{{order._confirmedAt}}">
      <text class="label">确认时间</text>
      <text class="value">{{order._confirmedAt}}</text>
    </view>
    <view class="info-row" wx:if="{{order._cancelledAt}}">
      <text class="label">取消时间</text>
      <text class="value">{{order._cancelledAt}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="card">
    <view class="section-title">出库商品</view>
    <view class="item-list">
      <view class="outbound-item" wx:for="{{order.items}}" wx:key="product_id" bindtap="onProductTap" data-id="{{item.product_id}}">
        <image class="item-image" src="{{item.image_url || '/images/placeholder.png'}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-name">{{item.product_name}}</text>
          <text class="item-code">{{item.product_code}}</text>
        </view>
        <view class="item-qty">× {{item.quantity}}</view>
      </view>
    </view>
    <view class="divider"></view>
    <view class="order-summary">
      共 {{order.items.length}} 种商品，合计 {{totalQuantity}} 件
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-bar" wx:if="{{order.status === 'pending' || order.status === 'reserved'}}">
    <view class="btn btn-ghost" bindtap="onCancel">
      {{order.type === 'outbound' ? '取消出库' : '取消预留'}}
    </view>
    <view class="btn btn-primary" bindtap="onConfirm">
      {{order.type === 'outbound' ? '确认出库' : '准备出库'}}
    </view>
  </view>
</view>
