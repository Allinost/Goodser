<view class="page-detail">
  <!-- 头图 -->
  <view class="detail-image-wrapper">
    <image class="detail-image" src="{{product.image_url || '/images/placeholder.png'}}" mode="aspectFill" />
  </view>

  <!-- 基本信息 -->
  <view class="card detail-card">
    <view class="detail-name">{{product.name}}</view>
    <view class="detail-code-row">
      <text class="detail-code">{{product.code}}</text>
      <text class="tag {{statusTagClass}}">{{statusLabel}}</text>
    </view>
    <!-- Tags -->
    <view class="detail-tags">
      <view class="detail-tag-item" wx:for="{{productTags}}" wx:key="_id" style="background: {{item.color}}18; border-color: {{item.color}}50">
        <view class="detail-tag-dot" style="background: {{item.color}}"></view>
        <text class="detail-tag-name" style="color: {{item.color}}">{{item.name}}</text>
        <text class="detail-tag-remove" bindtap="onRemoveTag" data-id="{{item._id}}">✕</text>
      </view>
      <view class="detail-tag-add" bindtap="onAddTag">
        <text class="detail-tag-add-icon">+</text>
        <text class="detail-tag-add-text">标签</text>
      </view>
    </view>
  </view>

  <!-- 详细信息 -->
  <view class="card detail-card">
    <view class="info-row">
      <text class="label">原价</text>
      <text class="value price">¥{{product.original_price}}</text>
    </view>
    <view class="info-row">
      <text class="label">市场价</text>
      <text class="value price">¥{{product.market_price}}</text>
    </view>
    <view class="info-row">
      <text class="label">预期出售价</text>
      <text class="value price highlight">¥{{product.expected_price}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="label">库存数量</text>
      <text class="value highlight">{{product.quantity}}{{product.reserved_quantity > 0 ? '（预留 ' + product.reserved_quantity + '）' : ''}}</text>
    </view>
    <view class="info-row">
      <text class="label">仓储位置</text>
      <text class="value">{{product.storage_location || '-'}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="label">主分区</text>
      <text class="value">{{product.main_zone}}</text>
    </view>
    <view class="info-row">
      <text class="label">子分区</text>
      <text class="value">{{product.sub_zone}}</text>
    </view>
    <view class="info-row">
      <text class="label">序号</text>
      <text class="value">{{product.seq_number}}</text>
    </view>
    <view class="info-row">
      <text class="label">状态</text>
      <text class="value">{{statusLabel}}（{{product.status_code}}）</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="label">备注</text>
      <text class="value">{{product.remark || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="label">创建时间</text>
      <text class="value">{{product.created_at}}</text>
    </view>
    <view class="info-row">
      <text class="label">更新时间</text>
      <text class="value">{{product.updated_at}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="btn btn-ghost" bindtap="onEdit">编辑</view>
    <view class="btn btn-danger" bindtap="onDelete">删除</view>
  </view>

  <!-- 标签选择弹窗 -->
  <view class="picker-mask" wx:if="{{showTagPicker}}" bindtap="hideTagPicker">
    <view class="dialog" catchtap="">
      <view class="dialog-title">选择标签</view>
      <view class="tag-dialog-list">
        <view
          class="tag-dialog-item {{isTagSelected(item._id) ? 'tag-dialog-item-selected' : ''}}"
          wx:for="{{availableTags}}"
          wx:key="_id"
          bindtap="onToggleTag"
          data-id="{{item._id}}"
          style="{{isTagSelected(item._id) ? 'background: ' + item.color + '18; border-color: ' + item.color + '50' : ''}}"
        >
          <view class="tag-color-dot" style="background: {{item.color}}"></view>
          <text class="tag-dialog-name" style="{{isTagSelected(item._id) ? 'color: ' + item.color : ''}}">{{item.name}}</text>
          <text class="tag-dialog-check" wx:if="{{isTagSelected(item._id)}}">✓</text>
        </view>
      </view>
      <view class="tag-dialog-new" bindtap="onShowNewTagDialog">+ 新建标签</view>
      <view class="dialog-actions">
        <view class="btn btn-ghost" bindtap="hideTagPicker">完成</view>
      </view>
    </view>
  </view>

  <!-- 新建标签弹窗 -->
  <view class="picker-mask" wx:if="{{showNewTagDialog}}" bindtap="hideNewTagDialog">
    <view class="dialog" catchtap="">
      <view class="dialog-title">新建标签</view>
      <view class="form-group">
        <text class="form-label">标签名称</text>
        <input class="dialog-input" placeholder="输入标签名称" value="{{newTagName}}" bindinput="onNewTagNameInput" />
      </view>
      <view class="form-group">
        <text class="form-label">标签颜色</text>
        <view class="color-options">
          <view
            class="color-dot {{newTagColor === item ? 'color-dot-active' : ''}}"
            wx:for="{{colorOptions}}"
            wx:key="*this"
            style="background: {{item}}"
            bindtap="onSelectColor"
            data-color="{{item}}"
          ></view>
        </view>
      </view>
      <view class="dialog-actions">
        <view class="btn btn-ghost" bindtap="hideNewTagDialog">取消</view>
        <view class="btn btn-primary" bindtap="onConfirmNewTag">创建</view>
      </view>
    </view>
  </view>
</view>
