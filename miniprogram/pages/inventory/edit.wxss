.page-edit {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 图片上传 */
.image-card {
  margin: 20rpx 24rpx;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.price-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

/* 标签选择 */
.tag-select-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.tag-select-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666666;
}

.tag-select-item-active {
  font-weight: 500;
}

.tag-color-dot-sm {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-inline-add {
  padding: 8rpx 16rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 新建标签弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inline-dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.inline-dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333333;
}

.inline-dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.inline-dialog-actions .btn {
  flex: 1;
  text-align: center;
}

/* 编码预览 */
.code-preview {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f0f7ff;
  border-radius: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.code-label {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.code-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1890ff;
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
}

/* 颜色选择 */
.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.color-dot-active {
  box-shadow: 0 0 0 4rpx #ffffff, 0 0 0 8rpx currentColor;
}
