.page-inventory {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #ffffff;
}

.inventory-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.inventory-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.selector-arrow {
  font-size: 20rpx;
  color: #999999;
}

.top-actions {
  display: flex;
  gap: 16rpx;
}

.top-btn {
  padding: 12rpx 24rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.top-btn-danger {
  background: #ff4d4f;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.sort-scroll {
  flex: 1;
  white-space: nowrap;
}

.sort-item {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  background: #f5f5f5;
}

.sort-active {
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 500;
}

.sort-arrow {
  font-size: 20rpx;
  margin-left: 4rpx;
}

.filter-btn {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 商品列表 */
.product-list {
  margin-top: 16rpx;
}

/* 弹窗遮罩 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.picker-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  overflow-y: auto;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.picker-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.picker-list {
  padding: 12rpx 0;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333333;
}

.picker-item-active {
  color: #1890ff;
  font-weight: 600;
}

/* 筛选面板 */
.filter-content {
  padding: 24rpx;
}

.filter-group {
  margin-bottom: 32rpx;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
}

.filter-tag-active {
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 500;
}

.filter-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f0f0f0;
}

.filter-footer .btn {
  flex: 1;
  text-align: center;
}

/* 对话框 */
.dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1001;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333333;
}

.dialog-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
}

.dialog-actions .btn {
  flex: 1;
  text-align: center;
}
