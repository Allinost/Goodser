.page-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.detail-image-wrapper {
  width: 100%;
  height: 480rpx;
  background: #f0f0f0;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-card {
  margin: 20rpx 24rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.detail-code-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-code {
  font-size: 26rpx;
  color: #999999;
  font-family: 'Courier New', monospace;
}

.price {
  font-family: 'Courier New', monospace;
}

.highlight {
  color: #1890ff;
  font-weight: 600;
}

/* Tags */
.detail-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.detail-tag-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.detail-tag-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.detail-tag-name {
  font-size: 24rpx;
  font-weight: 500;
}

.detail-tag-remove {
  font-size: 18rpx;
  opacity: 0.5;
  margin-left: 2rpx;
  padding: 4rpx;
}

.detail-tag-add {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 18rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 24rpx;
}

.detail-tag-add-icon {
  font-size: 24rpx;
  color: #999999;
  font-weight: 600;
}

.detail-tag-add-text {
  font-size: 22rpx;
  color: #999999;
}

/* 标签选择弹窗 */
.tag-dialog-list {
  max-height: 480rpx;
  overflow-y: auto;
  margin-bottom: 16rpx;
}

.tag-dialog-item {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  border: 2rpx dashed #d0d0d0;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.tag-dialog-item-selected {
  border-style: solid;
  font-weight: 500;
  background: #f0f5ff;
}

.tag-dialog-name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.tag-dialog-check {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 700;
}

.tag-dialog-new {
  text-align: center;
  padding: 16rpx 0;
  color: #1890ff;
  font-size: 28rpx;
  font-weight: 500;
  border-top: 2rpx solid #f0f0f0;
  margin-bottom: 8rpx;
}

.tag-color-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.bottom-bar .btn-ghost {
  border: 2rpx solid #1890ff;
  background: #ffffff;
}

/* 颜色选择 */
.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
}

.color-dot-active {
  box-shadow: 0 0 0 4rpx #ffffff, 0 0 0 8rpx currentColor;
}

/* 遮罩层 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗样式 */
.dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 32rpx;
}

.dialog-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 新建标签弹窗内表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.dialog-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.dialog-actions .btn {
  flex: 1;
  text-align: center;
}
