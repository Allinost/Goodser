.page-search-import {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 搜索结果 */
.search-results {
  margin-top: 16rpx;
}

.search-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.search-item:active {
  background: #f9f9f9;
}

.search-item-active {
  background: #e6f7ff;
  border-radius: 8rpx;
}

.search-item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.search-item-info {
  flex: 1;
  margin-left: 16rpx;
}

.search-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.search-item-code {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.search-item-stock {
  font-size: 22rpx;
  color: #1890ff;
  display: block;
}

.search-item-check {
  font-size: 32rpx;
  color: #1890ff;
  font-weight: 700;
  margin-left: 12rpx;
}

/* 已选商品 */
.selected-product-info {
  display: flex;
  align-items: center;
}

.sp-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.sp-info {
  margin-left: 16rpx;
}

.sp-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.sp-code {
  font-size: 24rpx;
  color: #999999;
  font-family: 'Courier New', monospace;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.zone-options {
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.zone-label {
  font-size: 26rpx;
  color: #666666;
}

/* 多选模式 */
.multi-select-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 8rpx;
}

.multi-select-toggle {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.multi-select-confirm-btn {
  font-size: 26rpx;
  color: #ffffff;
  background: #1890ff;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.multi-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.checkbox-inner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.checkbox-checked {
  background: #1890ff;
}

/* 多选已选商品列表 */
.multi-selected-list {
  margin-top: 12rpx;
}

.multi-selected-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.msi-info {
  flex: 1;
}

.msi-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.msi-code {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.msi-qty-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.msi-qty-input {
  width: 120rpx;
  height: 64rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

.msi-remove {
  font-size: 28rpx;
  color: #ff4d4f;
  padding: 8rpx;
}

.section-header {
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

/* 标签选择 */
.tag-select-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.tag-select-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #fafafa;
  border: 2rpx dashed #d9d9d9;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #999999;
}

.tag-select-item-active {
  border-style: solid;
  border-color: #1677ff;
  font-weight: 600;
  color: #1677ff;
  background: #e6f4ff;
}

.tag-checkmark {
  font-size: 20rpx;
  margin-left: 4rpx;
  font-weight: 700;
}

.tag-color-dot-sm {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-inline-add {
  padding: 8rpx 16rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 新建标签弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inline-dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.inline-dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333333;
}

.inline-dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.inline-dialog-actions .btn {
  flex: 1;
  text-align: center;
}

/* 颜色选择 */
.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.color-dot-active {
  box-shadow: 0 0 0 4rpx #ffffff, 0 0 0 8rpx currentColor;
}

.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.toggle-hint {
  font-size: 26rpx;
  color: #999999;
}

.zone-row {
  display: flex;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}
