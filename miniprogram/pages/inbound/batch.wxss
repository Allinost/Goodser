.page-batch-inbound {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 已添加列表 */
.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.batch-item {
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.batch-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.batch-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.batch-item-remove {
  font-size: 24rpx;
  color: #ff4d4f;
}

.batch-item-info {
  margin-top: 4rpx;
}

.batch-info-text {
  font-size: 24rpx;
  color: #999999;
}

/* 表单 */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.required {
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.price-row, .zone-row {
  display: flex;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 76rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-short {
  font-weight: 600;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}
