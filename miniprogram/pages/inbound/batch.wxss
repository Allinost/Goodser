.page-batch-inbound {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 已添加列表 */
.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.batch-item {
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.batch-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.batch-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.batch-item-remove {
  font-size: 24rpx;
  color: #ff4d4f;
}

.batch-item-info {
  margin-top: 4rpx;
}

.batch-info-text {
  font-size: 24rpx;
  color: #999999;
}

/* 表单 */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.required {
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.price-row, .zone-row {
  display: flex;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 76rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-short {
  font-weight: 600;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

/* 标签 */
.batch-item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.batch-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 4rpx;
}

.tag-select-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.tag-select-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666666;
}

.tag-select-item-active {
  font-weight: 500;
}

.tag-color-dot-sm {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.tag-inline-add {
  padding: 8rpx 16rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #999999;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inline-dialog {
  width: 600rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.inline-dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333333;
}

.inline-dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.inline-dialog-actions .btn {
  flex: 1;
  text-align: center;
}

/* 颜色选择 */
.color-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.color-dot-active {
  box-shadow: 0 0 0 4rpx #ffffff, 0 0 0 8rpx currentColor;
}
