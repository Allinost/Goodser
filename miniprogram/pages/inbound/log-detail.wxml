<view class="page-log-detail">
  <!-- 入库单头部 -->
  <view class="card log-header-card">
    <view class="log-header-row">
      <text class="log-title">{{logTypeLabel}}</text>
      <text class="tag tag-green">{{orderNo}}</text>
    </view>
    <view class="log-inventory" wx:if="{{inventoryName}}">
      <text class="log-inv-label">库存目录:</text>
      <text class="log-inv-name">{{inventoryName}}</text>
    </view>
    <view class="log-meta">
      <text class="log-time">{{log._createdAt}}</text>
    </view>
    <view class="info-row" wx:if="{{log.remark}}">
      <text class="label">备注</text>
      <text class="value">{{log.remark}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="card">
    <view class="section-title">入库商品</view>
    <view class="item-list">
      <view class="inbound-item" wx:for="{{log.items}}" wx:key="product_id" bindtap="onProductTap" data-id="{{item.product_id}}">
        <image class="item-image" src="{{item.image_url || '/images/placeholder.png'}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-name">{{item.product_name}}</text>
          <text class="item-code">{{item.product_code}}</text>
        </view>
        <view class="item-qty">+{{item.quantity}}</view>
      </view>
    </view>
    <view class="divider"></view>
    <view class="log-summary">
      共 {{log.items.length}} 种商品，合计 {{totalQuantity}} 件
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <view class="btn btn-ghost" bindtap="onEdit">编辑</view>
    <view class="btn btn-danger" bindtap="onDelete">删除</view>
  </view>

  <!-- 编辑弹窗 -->
  <view class="picker-mask" wx:if="{{showEditModal}}" bindtap="hideEditModal">
    <view class="edit-panel" catchtap="onDialogTap">
      <view class="edit-panel-header">
        <text class="edit-panel-title">编辑入库单</text>
        <text class="edit-panel-close" bindtap="hideEditModal">✕</text>
      </view>
      <scroll-view class="edit-panel-body" scroll-y>
        <!-- 搜索添加商品 -->
        <view class="edit-add-section">
          <view class="edit-add-header">
            <text class="edit-add-title">追加商品</text>
          </view>
          <view class="edit-search-row">
            <input
              class="edit-search-input"
              placeholder="搜索商品名称或编码..."
              value="{{editSearchKeyword}}"
              bindinput="onEditSearchInput"
              bindconfirm="onEditSearch"
              adjust-position="{{false}}"
            />
            <view class="edit-search-btn" bindtap="onEditSearch">搜索</view>
          </view>
          <!-- 搜索结果 -->
          <view class="edit-search-results" wx:if="{{showEditSearch && editSearchResults.length > 0}}">
            <view class="edit-multi-bar">
              <text class="edit-multi-toggle" bindtap="onToggleEditMultiSelect">
                {{editMultiSelectMode ? '取消多选' : '多选'}}
              </text>
              <view class="edit-multi-confirm" wx:if="{{editMultiSelectMode && editCheckedIds.length > 0}}" bindtap="onConfirmEditMultiSelect">
                确认添加 ({{editCheckedIds.length}})
              </view>
            </view>
            <view class="edit-search-item {{editMultiSelectMode && editCheckedIds.indexOf(item._id) > -1 ? 'edit-search-item-checked' : ''}}" wx:for="{{editSearchResults}}" wx:key="_id" bindtap="onEditAddProduct" data-product="{{item}}">
              <view class="edit-multi-checkbox" wx:if="{{editMultiSelectMode}}">
                <view class="edit-checkbox-inner {{editCheckedIds.indexOf(item._id) > -1 ? 'edit-checkbox-checked' : ''}}"></view>
              </view>
              <text class="edit-search-name">{{item.name}}</text>
              <text class="edit-search-code">{{item.code}}</text>
              <text class="edit-search-add" wx:if="{{!editMultiSelectMode}}">+ 添加</text>
            </view>
          </view>
          <view class="edit-search-empty" wx:elif="{{showEditSearch && editSearchResults.length === 0}}">
            <text>未找到商品</text>
          </view>
        </view>

        <view class="edit-divider"></view>

        <!-- 商品列表编辑 -->
        <view class="edit-item" wx:for="{{editItems}}" wx:key="product_id">
          <view class="edit-item-info">
            <text class="edit-item-name">{{item.product_name}}</text>
            <text class="edit-item-code">{{item.product_code}}</text>
          </view>
          <view class="edit-qty-row">
            <text class="edit-qty-btn" bindtap="onEditDecreaseQty" data-index="{{index}}">-</text>
            <input class="edit-qty-input" type="number" value="{{item.quantity}}" bindinput="onEditQtyInput" data-index="{{index}}" adjust-position="{{false}}" />
            <text class="edit-qty-btn" bindtap="onEditIncreaseQty" data-index="{{index}}">+</text>
            <text class="edit-item-remove" bindtap="onEditRemoveItem" data-index="{{index}}">✕</text>
          </view>
        </view>
        <!-- 备注 -->
        <view class="edit-remark-group">
          <text class="form-label">备注</text>
          <textarea class="form-textarea" placeholder="请输入备注" value="{{editRemark}}" bindinput="onEditRemarkInput" maxlength="200" adjust-position="{{false}}" />
        </view>
      </scroll-view>
      <view class="edit-panel-footer" style="padding-bottom: calc(24rpx + env(safe-area-inset-bottom) + {{keyboardHeight}}px)">
        <view class="btn btn-ghost" bindtap="hideEditModal">取消</view>
        <view class="btn btn-primary" bindtap="onSaveEdit">保存</view>
      </view>
    </view>
  </view>
</view>
