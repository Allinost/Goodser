<view class="page-batch-inbound">
  <!-- 选择库存目录 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">入库目录 <text class="required">*</text></text>
      <picker range="{{inventoryNames}}" value="{{inventoryIndex}}" bindchange="onInventoryChange">
        <view class="form-picker">
          <text>{{inventoryNames[inventoryIndex] || '请选择'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 已添加商品列表 -->
  <view class="card" wx:if="{{items.length > 0}}">
    <view class="section-header">
      <text class="section-title">已添加 {{items.length}} 件商品</text>
    </view>
    <view class="batch-list">
      <view class="batch-item" wx:for="{{items}}" wx:key="id">
        <view class="batch-item-header">
          <text class="batch-item-index">{{index + 1}}.</text>
          <text class="batch-item-name">{{item.name}}</text>
          <text class="batch-item-remove" bindtap="onRemoveItem" data-index="{{index}}">删除</text>
        </view>
        <view class="batch-item-info">
          <text class="batch-info-text">{{item.mainZone}}-{{item.subZone}} | 数量: {{item.quantity}} | {{item.statusCode}}</text>
          <view class="batch-item-tags" wx:if="{{item.tagNames.length > 0}}">
            <text class="batch-tag" wx:for="{{item.tagNames}}" wx:key="*this" wx:for-item="tn">{{tn}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="card">
    <view class="section-header">
      <text class="section-title">添加商品</text>
    </view>
    <view class="form-group">
      <text class="form-label">商品名称 <text class="required">*</text></text>
      <input class="form-input" placeholder="请输入商品名称" value="{{currentName}}" bindinput="onCurrentNameInput" />
    </view>
    <view class="price-row">
      <view class="form-group flex-1">
        <text class="form-label">原价</text>
        <input class="form-input" type="digit" placeholder="0.00" value="{{currentOriginalPrice}}" bindinput="onCurrentOriginalPriceInput" />
      </view>
      <view class="form-group flex-1">
        <text class="form-label">市场价</text>
        <input class="form-input" type="digit" placeholder="0.00" value="{{currentMarketPrice}}" bindinput="onCurrentMarketPriceInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">预期出售价</text>
      <input class="form-input" type="digit" placeholder="0.00" value="{{currentExpectedPrice}}" bindinput="onCurrentExpectedPriceInput" />
    </view>
    <view class="form-group">
      <text class="form-label">库存数量 <text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="0" value="{{currentQuantity}}" bindinput="onCurrentQuantityInput" />
    </view>
    <view class="form-group">
      <text class="form-label">仓储位置</text>
      <input class="form-input" placeholder="如: A区-1架-2层" value="{{currentStorageLocation}}" bindinput="onCurrentStorageLocationInput" />
    </view>
    <view class="form-group">
      <text class="form-label">备注信息</text>
      <input class="form-input" placeholder="请输入备注" value="{{currentRemark}}" bindinput="onCurrentRemarkInput" />
    </view>
    <view class="zone-row">
      <view class="form-group flex-1">
        <text class="form-label">主分区 <text class="required">*</text></text>
        <picker range="{{mainZones}}" value="{{currentMainZoneIndex}}" bindchange="onCurrentMainZoneChange">
          <view class="form-picker">
            <text>{{mainZones[currentMainZoneIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="form-group flex-1">
        <text class="form-label">子分区 <text class="required">*</text></text>
        <picker range="{{filteredSubZones}}" value="{{currentSubZoneIndex}}" bindchange="onCurrentSubZoneChange">
          <view class="form-picker">
            <text>{{filteredSubZones[currentSubZoneIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="form-group flex-1">
        <text class="form-label">状态 <text class="required">*</text></text>
        <picker range="{{statusCodeLabels}}" value="{{currentStatusCodeIndex}}" bindchange="onCurrentStatusCodeChange">
          <view class="form-picker">
            <text class="picker-short">{{statusCodes[currentStatusCodeIndex].code}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    <!-- 标签选择 -->
    <view class="form-group">
      <text class="form-label">商品标签</text>
      <view class="tag-select-area">
        <view
          class="tag-select-item {{currentTagIds.indexOf(item._id) > -1 ? 'tag-select-item-active' : ''}}"
          wx:for="{{allTags}}"
          wx:key="_id"
          bindtap="onToggleTag"
          data-id="{{item._id}}"
        >
          <view class="tag-color-dot-sm" style="background: {{item.color}}"></view>
          <text>{{item.name}}</text>
          <text class="tag-checkmark" wx:if="{{currentTagIds.indexOf(item._id) > -1}}">✓</text>
        </view>
        <view class="tag-inline-add" bindtap="onInlineAddTag">+ 新建</view>
      </view>
    </view>
    <view class="btn btn-ghost" bindtap="onAddToBatch">+ 添加到列表</view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar" wx:if="{{items.length > 0}}">
    <view class="btn btn-primary btn-block {{submitting ? 'btn-disabled' : ''}}" bindtap="{{submitting ? '' : 'onSubmit'}}">{{submitting ? '入库中...' : '确认批量入库 (' + items.length + '件)'}}</view>
  </view>

  <!-- 新建标签弹窗 -->
  <view class="picker-mask" wx:if="{{showNewTagDialog}}" bindtap="hideNewTagDialog">
    <view class="inline-dialog" catchtap="onDialogTap">
      <view class="inline-dialog-title">新建标签</view>
      <view class="form-group">
        <text class="form-label">标签名称</text>
        <input class="form-input" placeholder="输入标签名称" value="{{newTagName}}" bindinput="onNewTagNameInput" adjust-position="{{false}}" />
      </view>
      <view class="form-group">
        <text class="form-label">标签颜色</text>
        <view class="color-options">
          <view
            class="color-dot {{newTagColor === item ? 'color-dot-active' : ''}}"
            wx:for="{{colorOptions}}"
            wx:key="*this"
            style="background: {{item}}"
            bindtap="onSelectColor"
            data-color="{{item}}"
          ></view>
        </view>
      </view>
      <view class="inline-dialog-actions">
        <view class="btn btn-ghost" bindtap="hideNewTagDialog">取消</view>
        <view class="btn btn-primary" bindtap="onConfirmNewTag">创建</view>
      </view>
    </view>
  </view>
</view>
