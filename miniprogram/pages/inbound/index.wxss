.page-inbound {
  min-height: 100vh;
  background: #f5f5f5;
}

.method-card {
  margin: 20rpx 24rpx;
}

.method-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.method-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #ffffff;
}

.method-item:active {
  background: #f9f9f9;
}

.method-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.method-info {
  flex: 1;
}

.method-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.method-desc {
  font-size: 24rpx;
  color: #999999;
}

.method-arrow {
  font-size: 36rpx;
  color: #cccccc;
  margin-left: 12rpx;
}

/* 最近入库记录 */
.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.log-item:last-child {
  border-bottom: none;
}

.log-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.log-info {
  flex: 1;
}

.log-type {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.log-products {
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 320rpx;
  display: block;
}

.log-right {
  text-align: right;
}

.log-qty {
  font-size: 30rpx;
  font-weight: 600;
  color: #52c41a;
  display: block;
}

.log-time {
  font-size: 22rpx;
  color: #999999;
}
