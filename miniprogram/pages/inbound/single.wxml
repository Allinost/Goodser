<view class="page-single-inbound">
  <!-- 选择库存目录 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">入库目录 <text class="required">*</text></text>
      <picker range="{{inventoryNames}}" value="{{inventoryIndex}}" bindchange="onInventoryChange">
        <view class="form-picker">
          <text>{{inventoryNames[inventoryIndex] || '请选择'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 商品图片 -->
  <view class="card image-card">
    <text class="form-label">商品头图</text>
    <view class="image-upload" bindtap="onChooseImage">
      <image class="upload-preview" wx:if="{{imageUrl}}" src="{{imageUrl}}" mode="aspectFill" />
      <view class="upload-placeholder" wx:else>
        <text class="upload-icon">📷</text>
        <text class="upload-text">上传图片</text>
      </view>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">商品名称 <text class="required">*</text></text>
      <input class="form-input" placeholder="请输入商品名称" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="price-row">
      <view class="form-group flex-1">
        <text class="form-label">原价</text>
        <input class="form-input" type="digit" placeholder="0.00" value="{{originalPrice}}" bindinput="onOriginalPriceInput" />
      </view>
      <view class="form-group flex-1">
        <text class="form-label">市场价</text>
        <input class="form-input" type="digit" placeholder="0.00" value="{{marketPrice}}" bindinput="onMarketPriceInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">预期出售价</text>
      <input class="form-input" type="digit" placeholder="0.00" value="{{expectedPrice}}" bindinput="onExpectedPriceInput" />
    </view>
    <view class="form-group">
      <text class="form-label">库存数量 <text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="0" value="{{quantity}}" bindinput="onQuantityInput" />
    </view>
    <view class="form-group">
      <text class="form-label">仓储位置</text>
      <input class="form-input" placeholder="如: A区-1架-2层" value="{{storageLocation}}" bindinput="onStorageLocationInput" />
    </view>
    <view class="form-group">
      <text class="form-label">备注信息</text>
      <textarea class="form-textarea" placeholder="请输入备注" value="{{remark}}" bindinput="onRemarkInput" maxlength="200" />
    </view>
  </view>

  <!-- 分区与状态选择 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">主分区 <text class="required">*</text></text>
      <picker range="{{mainZones}}" value="{{mainZoneIndex}}" bindchange="onMainZoneChange">
        <view class="form-picker">
          <text>{{mainZones[mainZoneIndex] || '请选择'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">子分区 <text class="required">*</text></text>
      <picker range="{{filteredSubZones}}" value="{{subZoneIndex}}" bindchange="onSubZoneChange">
        <view class="form-picker">
          <text>{{filteredSubZones[subZoneIndex] || '请选择'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="form-group">
      <text class="form-label">状态编码 <text class="required">*</text></text>
      <picker range="{{statusCodeLabels}}" value="{{statusCodeIndex}}" bindchange="onStatusCodeChange">
        <view class="form-picker">
          <text>{{statusCodeLabels[statusCodeIndex] || '请选择'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 编码预览 -->
    <view class="code-preview" wx:if="{{previewCode}}">
      <text class="code-label">生成编码</text>
      <text class="code-value">{{previewCode}}</text>
    </view>
  </view>

  <!-- 标签选择 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">商品标签</text>
      <view class="tag-select-area">
        <view
          class="tag-select-item {{selectedTagIds.indexOf(item._id) > -1 ? 'tag-select-item-active' : ''}}"
          wx:for="{{allTags}}"
          wx:key="_id"
          bindtap="onToggleTag"
          data-id="{{item._id}}"
        >
          <view class="tag-color-dot-sm" style="background: {{item.color}}"></view>
          <text>{{item.name}}</text>
          <text class="tag-checkmark" wx:if="{{selectedTagIds.indexOf(item._id) > -1}}">✓</text>
        </view>
        <view class="tag-inline-add" bindtap="onInlineAddTag">+ 新建</view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="btn btn-primary btn-block {{submitting ? 'btn-disabled' : ''}}" bindtap="{{submitting ? '' : 'onSubmit'}}">{{submitting ? '入库中...' : '确认入库'}}</view>
  </view>

  <!-- 新建标签弹窗 -->
  <view class="picker-mask" wx:if="{{showNewTagDialog}}" bindtap="hideNewTagDialog">
    <view class="inline-dialog" catchtap="onDialogTap">
      <view class="inline-dialog-title">新建标签</view>
      <view class="form-group">
        <text class="form-label">标签名称</text>
        <input class="form-input" placeholder="输入标签名称" value="{{newTagName}}" bindinput="onNewTagNameInput" adjust-position="{{false}}" />
      </view>
      <view class="form-group">
        <text class="form-label">标签颜色</text>
        <view class="color-options">
          <view
            class="color-dot {{newTagColor === item ? 'color-dot-active' : ''}}"
            wx:for="{{colorOptions}}"
            wx:key="*this"
            style="background: {{item}}"
            bindtap="onSelectColor"
            data-color="{{item}}"
          ></view>
        </view>
      </view>
      <view class="inline-dialog-actions">
        <view class="btn btn-ghost" bindtap="hideNewTagDialog">取消</view>
        <view class="btn btn-primary" bindtap="onConfirmNewTag">创建</view>
      </view>
    </view>
  </view>
</view>
